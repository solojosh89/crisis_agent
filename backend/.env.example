# Copy this file to .env and fill in your real values.
# NEVER commit the real .env — it is gitignored.

# Required — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Server port
PORT=3001

# Optional — SMS alerts to emergency contacts.
# The app works fully without these; SMS shows as "pending setup".
# Get credentials at https://account.africastalking.com
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
